{
  "version": 2,
  "installCommand": "npm install && npm --prefix client install",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/dist/$1"
    }
  ]
}
